    "elements": {
      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Historial Clínico Dinámico por Ave",
          "description": "Línea de tiempo interactiva que renderiza cronológicamente las transiciones en el estado biológico de una gallina específica, seleccionada mediante el identificador analítico del tablero. Este panel mapea los cambios temporales de salud basándose en los registros consolidados en la PC Central, permitiendo un seguimiento quirúrgico e individualizado del bienestar animal dentro de la granja.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "mysql",
                      "version": "v0",
                      "datasource": {
                        "name": "eflwdoiqo44jke"
                      },
                      "spec": {
                        "dataset": "sistema_avicola",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n  fecha_hora / 1000 AS time,\r\n  estado_salud AS \"Estado de Salud\"\r\nFROM historial_salud\r\nWHERE id_gallina = '$gallina'\r\nORDER BY fecha_hora ASC;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
