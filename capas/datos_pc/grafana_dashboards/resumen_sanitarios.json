      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Distribución Actual del Estado de Salud del Lote",
          "description": "Gráfico analítico que representa la proporción porcentual y volumétrica de las aves según su estado biológico actual (Saludable, Letárgica, Herida o Problema con Alimento). Permite al personal veterinario diagnosticar rápidamente anomalías sanitarias globales en la granja mediante datos consolidados en la PC Central.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "mysql",
                      "version": "v0",
                      "datasource": {
                        "name": "eflwdoiqo44jke"
                      },
                      "spec": {
                        "dataset": "sistema_avicola",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n  SUM(CASE WHEN estado_salud = 'Saludable' THEN 1 ELSE 0 END) AS \"Saludable\",\r\n  SUM(CASE WHEN estado_salud = 'En observacion' THEN 1 ELSE 0 END) AS \"En Observación\",\r\n  SUM(CASE WHEN estado_salud = 'En tratamiento' THEN 1 ELSE 0 END) AS \"En Tratamiento\",\r\n  SUM(CASE WHEN estado_salud = 'Grave' THEN 1 ELSE 0 END) AS \"Grave\"\r\nFROM (\r\n  SELECT \r\n    id_gallina,\r\n    estado_salud,\r\n    ROW_NUMBER() OVER (PARTITION BY id_gallina ORDER BY fecha_hora DESC) AS fila\r\n  FROM historial_salud\r\n) AS ultimos_registros\r\nWHERE fila = 1;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
