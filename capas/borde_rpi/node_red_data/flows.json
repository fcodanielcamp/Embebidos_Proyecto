    {
        "id": "1c5b596d652a0796",
        "type": "function",
        "z": "738ecc0fd85310c9",
        "name": "function 2",
        "func": "// 1. Definimos la consulta con signos de interrogación como marcadores (placeholders)\nlet query = \"INSERT INTO historial_salud (id_gallina, id_sensor, estado_salud, fecha_hora) VALUES (?, ?, ?, ?);\";\n\n// 2. Creamos un array con los valores exactos en el orden de los marcadores\n// Usamos String() para asegurar que los textos sean cadenas y no objetos\nlet valores = [\n    String(msg.payload.uid),\n    \"3\",\n    String(msg.payload.estado),\n    msg.payload.timestamp\n];\n\n// 3. Reiniciamos el mensaje enviando la query y los parámetros por separado\n// Esta estructura es la que espera el nodo MySQL para consultas parametrizadas\nreturn {\n    topic: query,\n    payload: valores\n};",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1060,
        "y": 540,
        "wires": [
