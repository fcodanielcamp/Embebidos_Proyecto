    {
        "id": "d0d927ca3d92e94b",
        "type": "function",
        "z": "738ecc0fd85310c9",
        "name": "function 1",
        "func": "// El timestamp viene en milisegundos, InfluxDB lo acepta bien así\nmsg.payload = [\n    {\n        // Campos (Valores numéricos o datos que quieres medir)\n        id_sensor: msg.payload.id_sensor,\n        uid: msg.payload.uid\n    }\n];\n\n// Asignamos el timestamp original del mensaje para que Influx use ese y no el actual\nmsg.timestamp = msg.payload.timestamp;\n\nreturn msg;",
