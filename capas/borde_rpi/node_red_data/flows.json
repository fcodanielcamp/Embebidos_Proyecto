    {
        "id": "d0d927ca3d92e94b",
        "type": "function",
        "z": "738ecc0fd85310c9",
        "name": "function 1",
        "func": "// 1. Extraemos los datos que vienen del ESP32 (o del Inyect de prueba)\nvar rfidData = msg.payload; \n\n// 2. Preparamos los campos de datos (Fields)\nmsg.payload = {\n    id_sensor: rfidData.id_sensor,\n    uid: rfidData.uid\n};\n\n// 3. MAPEO DEL TIEMPO ORIGINALE\n// Tomamos el timestamp que generó el ESP32 y lo pasamos a msg.timestamp.\n// El nodo InfluxDB Out usará este valor para la columna _time.\nmsg.timestamp = rfidData.timestamp; \n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
