    {
        "id": "01a16cedcb94cc84",
        "type": "function",
        "z": "738ecc0fd85310c9",
        "name": "Validador",
        "func": "// Convertimos el mensaje entrante a número\nlet seleccion = parseInt(msg.payload);\n\n// Validamos que sea un patrón permitido (1, 2 o 3)\nif (seleccion >= 1 && seleccion <= 3) {\n    msg.payload = { \"patron\": seleccion };\n    return msg;\n}\n// Si no es válido, descartamos el mensaje\nreturn null;",
